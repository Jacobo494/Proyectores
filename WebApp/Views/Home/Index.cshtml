@model IEnumerable<WebApp.Models.Proyectores>
@{
    ViewData["Title"] = "Inicio";
}
@if (Model is not null)
{
    <div class="container">
        <h1>Lista de Proyectores</h1>
        <h3>Información de los proyectores registrados</h3>

         @if (Model.Any<Proyectores>()) 
          @*  @if (Model.Count<Proyectores>() > 0) *@
        {
            
       
        <table>
            <thead>


                <tr>
                    <th># Proyector</th>
                    <th>Marca</th>
                    <th>Modelo</th>
                    <th># de serie</th>
                    <th>Situacion</th>
                    <th>Fecha de alta</th>
                </tr>
            </thead>

            <tbody>

                @foreach (Proyectores proyector in Model)
                {
                    <tr>
                        <td>@proyector.Id</td>
                        <td>@proyector.Marca</td>
                        <td>@proyector.Modelo</td>
                        <td>@proyector.NumeroDeSerie</td>
                        <td>@proyector.situacion</td>
                        <td>@proyector.FechaDeAlta.ToShortDateString()</td>
                    </tr>
                }


            </tbody>
        </table>

        } else { <h4>No hay proyectores registrados.</h4>}

    </div>

}


